---
// The home page is now CMS CONTENT, not hard-coded: it's the page with slug "home"
// in the default locale, rendered through the exact same template pipeline as any
// other page (PagePage → the chosen preset). Edit it in the CMS: Pages → "Inicio",
// pick a Template, fill its slots. This is the loop — a designed page, owned by the
// user, editable without code.
import PagePage from "../components/PagePage.astro";
import { DEFAULT_LOCALE, splitId } from "../lib/i18n";
import { publishedPages } from "../lib/routing";

const pages = await publishedPages();
const home = pages.find((p) => {
  const { locale, slug } = splitId(p.id);
  return slug === "home" && locale === DEFAULT_LOCALE;
});
---

{home && <PagePage page={home} locale={DEFAULT_LOCALE} />}
