---
import { getCollection } from "astro:content";
import flow from "../../data/flow.json";
import "../../styles/flow.css";

const locale = "en";
const cover = flow.nodes.find((n) => n.id === flow.startNode) as any;

const listingsData = (
  await getCollection("listings", ({ data }) =>
    import.meta.env.PROD ? data.draft !== true : true,
  )
)
  .filter((l) => l.data.listingStatus !== "sold" && l.data.listingStatus !== "rented")
  .map((l) => ({
    slug: l.id,
    title: l.data.title,
    image: l.data.featuredImage ?? null,
    listingType: l.data.listingType,
    priceSale: l.data.priceSale ?? null,
    priceRent: l.data.priceRent ?? null,
    bedrooms: l.data.bedrooms ?? null,
    listingStatus: l.data.listingStatus,
    flowTags: l.data.flowTags ?? [],
    region: l.data.region ?? null,
  }));

const leadEndpoint = import.meta.env.PUBLIC_LEAD_ENDPOINT ?? "";
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600&family=Jost:wght@300;400;500&display=swap" rel="stylesheet" />
    <title>Find your place — La Perle Panamá</title>
    <meta name="robots" content="noindex" />
    <style>
      *, *::before, *::after { box-sizing: border-box; }
      html, body { margin: 0; height: 100%; }
      body.flow-shell { background: #10202a; color: #f4efe6; font-family: var(--font-sans, "Jost", sans-serif); }
      .flow-exit { position: fixed; top: 1rem; right: 1.2rem; z-index: 50; color: #e8c8a0; font-size: 0.7rem; letter-spacing: 0.2em; text-decoration: none; text-transform: uppercase; }
      .flow-logo { position: fixed; top: 1rem; left: 1.2rem; z-index: 50; font-family: var(--font-serif, "Cormorant Garamond", serif); color: #e8c8a0; letter-spacing: 0.1em; text-decoration: none; }
      .match-grid { display: grid; gap: 0.6rem; }
      .match-card { display: flex; gap: 0.8rem; align-items: center; border: 1px solid rgba(244,239,230,.35); background: rgba(20,30,38,.45); text-decoration: none; color: #f4efe6; padding: 0.5rem; }
      .match-card__img { width: 84px; height: 60px; background-size: cover; background-position: center; flex: none; }
      .match-card__body { display: flex; flex-direction: column; align-items: flex-start; gap: 0.15rem; font-size: 0.85rem; text-align: left; }
      .match-card__body span { color: #e8c8a0; }
    </style>
  </head>
  <body class="flow-shell">
    <a class="flow-logo" href="/en/">La Perle Panamá</a>
    <a class="flow-exit" href="/en/">Exit ✕</a>
    <div class="qroot" id="qroot" data-locale={locale} data-lead-endpoint={leadEndpoint}>
      <div class="qcard">
        <div class="qcard__bg" style={`background-image:linear-gradient(180deg,rgba(8,20,28,.2),rgba(8,20,28,.55) 55%,rgba(8,20,28,.92)),url('${cover.image}')`}></div>
        <div class="qbody" style="text-align:center;margin-top:auto;margin-bottom:auto">
          <div class="qkicker">{cover.kicker_en}</div>
          <h2 class="qtitle" style="font-size:2.4rem">{cover.prompt_en}</h2>
          <p style="font-weight:300;opacity:.85;margin-bottom:1.3rem">{cover.sub_en}</p>
          <button class="qcta" id="q-begin">{cover.cta_en} ›</button>
        </div>
      </div>
    </div>
    <script is:inline type="application/json" id="flow-data" set:html={JSON.stringify(flow)} />
    <script is:inline type="application/json" id="listings-data" set:html={JSON.stringify(listingsData)} />
    <script is:inline type="module" src="/scripts/flow/engine.js"></script>
  </body>
</html>
