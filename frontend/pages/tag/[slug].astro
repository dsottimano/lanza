---
import { getCollection } from "astro:content";
import Base from "../../layouts/Base.astro";
import Archive from "../../components/Archive.astro";
import { splitId, DEFAULT_LOCALE } from "../../lib/i18n";
import { entryAlternates } from "../../lib/alternates";

// Default-locale (EN) tag archives at /tag/<stem>/. Posts store bare term stems.
// ES/FR archives come from [locale]/tag/[slug].astro (Phase C).
export async function getStaticPaths() {
  const tags = await getCollection("tags");
  return tags
    .map((tag) => ({ tag, ...splitId(tag.id) }))
    .filter(({ locale }) => locale === DEFAULT_LOCALE)
    .map(({ tag, slug }) => ({ params: { slug }, props: { tag } }));
}

const locale = DEFAULT_LOCALE;
const { tag } = Astro.props;
const stem = splitId(tag.id).slug;
const posts = (
  await getCollection(
    "posts",
    ({ data }) =>
      (import.meta.env.PROD ? data.draft !== true : true) &&
      data.tags.includes(stem),
  )
)
  .filter((p) => splitId(p.id).locale === locale)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const alternates = await entryAlternates("tags", stem, "tag");
---

<Base
  locale={locale}
  alternates={alternates}
  seo={{ title: `Tag: ${tag.data.title}`, description: tag.data.description }}
>
  <Archive
    heading={`Tag: ${tag.data.title}`}
    locale={locale}
    posts={posts}
    description={tag.data.description}
    emptyText="No posts with this tag yet."
  />
</Base>
