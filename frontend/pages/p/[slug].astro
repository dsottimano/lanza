---
import { getCollection } from "astro:content";
import Base from "../../layouts/Base.astro";
import ListingDetail from "../../components/ListingDetail.astro";
import { resolveTemplate } from "../../lib/templates";

export async function getStaticPaths() {
  const listings = await getCollection("listings", ({ data }) =>
    import.meta.env.PROD ? data.draft !== true : true,
  );
  return listings.map((listing) => ({ params: { slug: listing.id }, props: { listing } }));
}

const { listing } = Astro.props;
const d = listing.data;
const template = resolveTemplate(d);
---

<Base
  template={template}
  seo={{
    title: d.title,
    description: d.seo?.metaDescription,
    ogImage: d.seo?.ogImage || d.featuredImage,
    ogType: "article",
    ...(d.seo ?? {}),
  }}
>
  <ListingDetail listing={listing} locale="es" template={template} />
</Base>
