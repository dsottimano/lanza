---
import Base from "../layouts/Base.astro";
import PageArticle from "../components/PageArticle.astro";
import { splitId, DEFAULT_LOCALE } from "../lib/i18n";
import { entryAlternates } from "../lib/alternates";
import { publishedPages } from "../lib/routing";

// Standalone Pages (About, Contact, …) render at /<slug>. Static paths only —
// this is not a runtime catch-all; getStaticPaths emits exactly the page slugs.
// Default-locale (EN) only; ES/FR pages come from [locale]/[...slug].astro.
export async function getStaticPaths() {
  const pages = await publishedPages();
  return pages
    .map((page) => ({ page, ...splitId(page.id) }))
    .filter(({ locale }) => locale === DEFAULT_LOCALE)
    .map(({ page, slug }) => ({ params: { slug }, props: { page } }));
}

const { page } = Astro.props;
const alternates = await entryAlternates("pages", splitId(page.id).slug, "");
---

<Base
  locale={DEFAULT_LOCALE}
  alternates={alternates}
  seo={{
    title: page.data.title,
    description: page.data.description,
    ogType: "website",
    ...(page.data.seo ?? {}),
    ogImage: page.data.seo?.ogImage || page.data.featuredImage,
  }}
>
  <PageArticle page={page} />
</Base>
