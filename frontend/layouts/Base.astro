---
import "../styles/site.css";
import Seo from "../components/Seo.astro";
import appearance from "../data/appearance.json";
import type { PageSeo } from "../lib/seo";
import type { ArticleInput } from "../lib/jsonld";
import type { Alternate } from "../lib/alternates";
import { DEFAULT_LOCALE, type Locale } from "../lib/i18n";
import { getMenu, getSeoDefaults, resolveDevices } from "../lib/site";
import { mirrorPath } from "../lib/locale";

interface Props {
  seo?: PageSeo;
  article?: ArticleInput | null;
  // Active locale — drives <html lang>, the per-locale menu/SEO, and the ES·EN
  // switcher. La Perle is UI-only bilingual: "es" (default, root) or "en" (/en/*).
  locale?: Locale;
  // Accepted for drop-in compatibility with the platform's shared page
  // components (PostPage/PagePage/…). Single content locale ⇒ unused here; the
  // ES·EN switcher is built from mirrorPath instead.
  alternates?: Alternate[];
}

const { seo = {}, article = null, locale = DEFAULT_LOCALE } = Astro.props;

// Site-wide theme (Settings → Appearance). Drives the public CSS via data-theme.
const theme = appearance.theme ?? "editorial";
const siteName = getSeoDefaults(locale).siteName || "Site";
const year = new Date().getFullYear();

const isEn = locale === "en";
const path = Astro.url.pathname;
const altPath = mirrorPath(path);
const homeUrl = isEn ? "/en/" : "/";

// Nav from the editable per-locale Settings → Menu. La Perle uses one flat
// header list (its responsive CSS handles layout), so we render the desktop
// menu; URLs are authored locale-correct in menu.es.json / menu.en.json.
const nav = resolveDevices(getMenu(locale).header).desktop;
---

<!doctype html>
<html lang={locale} data-theme={theme}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600&family=Jost:wght@300;400;500&display=swap"
      rel="stylesheet"
    />
    <Seo seo={seo} article={article} locale={locale} />
  </head>
  <body>
    <header class="site-header">
      <div class="bar">
        <a class="brand" href={homeUrl}>{siteName}</a>
        <nav class="site-nav">
          {nav.map((item) => <a href={item.url}>{item.label}</a>)}
          <span class="nav-locale">
            {isEn ? <a href={altPath}>ES</a> : <span class="is-active">ES</span>}
            <span>·</span>
            {isEn ? <span class="is-active">EN</span> : <a href={altPath}>EN</a>}
          </span>
        </nav>
      </div>
    </header>

    <slot />

    <footer class="site-footer">
      <div class="bar">© {year} {siteName}</div>
    </footer>

    {/* Agent surface: window.lanza read API (see public/lanza.js). Static, deferred, cached site-wide. */}
    <script src="/lanza.js" defer is:inline></script>
  </body>
</html>
