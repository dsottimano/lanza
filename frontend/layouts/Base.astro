---
import "../styles/site.css";
import Seo from "../components/Seo.astro";
import appearance from "/data/appearance.json";
import type { PageSeo } from "../lib/seo";
import type { ArticleInput } from "../lib/jsonld";
import type { Alternate } from "../lib/alternates";
import { DEFAULT_LOCALE, LOCALES, localeUrl, type Locale } from "../lib/i18n";
import { getMenu, getSeoDefaults, resolveDevices } from "../lib/site";
import { isLanding } from "../lib/templates";
import { resolveBrand } from "../lib/appearance";

interface Props {
  seo?: PageSeo;
  article?: ArticleInput | null;
  // Active locale — drives <html lang>, the per-locale menu/SEO, and the language
  // switcher. Which locales exist and which is default come from data/site.json.
  locale?: Locale;
  // This page's cross-locale URLs — feeds the hreflang tags (via Seo) and the
  // header language switcher (one link per locale, active one marked).
  alternates?: Alternate[];
  // Resolved template name (frontend/lib/templates.ts). "landing" strips the
  // header nav + ES·EN switcher, keeping just the brand as the way home —
  // structurally omitted (not display:none) so the page stays clean + cacheable.
  template?: string;
}

const { seo = {}, article = null, locale = DEFAULT_LOCALE, alternates = [], template } = Astro.props;

const landing = isLanding(template ?? "default");

// Brand (Settings → Brand): inline custom-property overrides that beat the base
// design tokens (site.css :root), a motion flag, and any custom-font stylesheet.
// There is no theme switch — the base look lives in site.css; Brand owns it.
const brand = resolveBrand(appearance);
const siteName = getSeoDefaults(locale).siteName || "Site";
const year = new Date().getFullYear();

// The brand links home in the active locale; the default locale sits at the root.
const homeUrl = localeUrl(locale, "");

// Nav from the editable per-locale Settings → Menu. The theme uses one flat
// header list (its responsive CSS handles layout), so we render the desktop
// menu; URLs are authored locale-correct in menu.es.json / menu.en.json.
const nav = resolveDevices(getMenu(locale).header).desktop;
---

<!doctype html>
<html lang={locale} data-motion={brand.motion} style={brand.styleVars || undefined}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    {/* Base design fonts: Jost (the wordmark's geometric sans — display + body)
        and JetBrains Mono (nav/footer/pipeline machine-truth). Always loaded so
        an un-branded site still looks right; Brand's own fonts load additively. */}
    <link
      href="https://fonts.googleapis.com/css2?family=Jost:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    {brand.fontHref && <link href={brand.fontHref} rel="stylesheet" />}
    {/* Wordmark favicons + PWA manifest (public/favicon, from lanza-brand). */}
    <link rel="icon" href="/favicon/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" href="/favicon/icon-512.png" sizes="512x512" />
    <link rel="apple-touch-icon" href="/favicon/apple-touch-icon.png" />
    <link rel="manifest" href="/favicon/site.webmanifest" />
    <meta name="theme-color" content="#f3f1ea" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#17140f" media="(prefers-color-scheme: dark)" />
    <Seo seo={seo} article={article} locale={locale} alternates={alternates} />
  </head>
  <body>
    <header class:list={["site-header", landing && "landing"]}>
      <div class="bar">
        <a class="brand" href={homeUrl} aria-label={siteName}>
          <svg class="wordmark" viewBox="-16 24 812 232" role="img" aria-label={siteName} xmlns="http://www.w3.org/2000/svg">
            <g fill="currentColor">
              <path d="M 14.04,240 H 48.62 V 47.86 H 14.04 Z"/>
              <path d="m 212.29994,95.96 h -31.72 v 19.24 c -11.96,-15.86 -26.26,-22.62 -47.06,-22.62 -42.64,0 -73.32,31.98 -73.32,75.92 0,43.42 30.42,74.88 72.54,74.88 20.28,0 34.06,-6.24 47.84,-22.1 V 240 h 31.72 z m -75.14,28.34 c 24.7,0 42.38,18.46 42.38,44.72 0,10.4 -4.16,22.36 -10.4,29.64 -7.02,8.58 -18.2,13 -31.46,13 -25.22,0 -42.64,-17.16 -42.64,-42.38 0,-26.26 17.42,-44.98 42.12,-44.98 z"/>
              <path d="m 228.03991,240 h 34.58 v -67.86 c 0,-19.24 1.3,-27.56 5.72,-34.58 5.46,-8.58 14.3,-13.26 25.48,-13.26 9.1,0 16.12,3.12 20.8,9.1 4.68,6.24 6.76,16.9 6.76,36.14 V 240 h 34.58 v -77.22 c 0,-25.74 -2.6,-38.22 -10.4,-49.4 -9.36,-13.52 -24.96,-20.8 -44.98,-20.8 -16.64,0 -27.82,4.68 -40.56,17.16 V 95.96 h -31.98 z"/>
              <path d="m 364.93917,240 h 109.72 v -30.94 h -68.38 l 63.44,-82.16 V 95.96 h -97.5 v 30.94 h 56.16 l -63.44,82.16 z"/>
              <path d="m 626.63886,95.96 h -31.72 v 19.24 c -11.96,-15.86 -26.26,-22.62 -47.06,-22.62 -42.64,0 -73.32,31.98 -73.32,75.92 0,43.42 30.42,74.88 72.54,74.88 20.28,0 34.06,-6.24 47.84,-22.1 V 240 h 31.72 z m -75.14,28.34 c 24.7,0 42.38,18.46 42.38,44.72 0,10.4 -4.16,22.36 -10.4,29.64 -7.02,8.58 -18.2,13 -31.46,13 -25.22,0 -42.64,-17.16 -42.64,-42.38 0,-26.26 17.42,-44.98 42.12,-44.98 z"/>
            </g>
            <g class="wordmark__arrow" transform="translate(636,100) scale(1.35)" fill="none" stroke="currentColor" stroke-width="19" stroke-linecap="round" stroke-linejoin="round">
              <path d="M20 80 L80 20"/>
              <path d="M80 48 L80 20 L52 20"/>
            </g>
          </svg>
        </a>
        {!landing && (
          <nav class="site-nav">
            {nav.map((item) => <a href={item.url}>{item.label}</a>)}
            {LOCALES.length > 1 && (
              <span class="nav-locale">
                {LOCALES.map((l, i) => {
                  const url = alternates.find((a) => a.locale === l)?.url ?? localeUrl(l, "");
                  const code = l.toUpperCase();
                  return (
                    <>
                      {i > 0 && <span>·</span>}
                      {l === locale ? (
                        <span class="is-active">{code}</span>
                      ) : (
                        <a href={url}>{code}</a>
                      )}
                    </>
                  );
                })}
              </span>
            )}
          </nav>
        )}
      </div>
    </header>

    <slot />

    <footer class:list={["site-footer", landing && "landing"]}>
      <div class="bar">© {year} {siteName}</div>
    </footer>

    {/* Agent surface: window.lanza read API (see public/lanza.js). Static, deferred, cached site-wide. */}
    <script src="/lanza.js" defer is:inline></script>
  </body>
</html>
