---
import "../styles/site.css";
import Seo from "../components/Seo.astro";
import appearance from "../data/appearance.json";
import type { PageSeo } from "../lib/seo";
import type { ArticleInput } from "../lib/jsonld";
import { localeUrl, LOCALE_LABEL, DEFAULT_LOCALE, type Locale } from "../lib/i18n";
import { getMenu, getSeoDefaults, groupByDevice, menuIsEmpty, type Device } from "../lib/site";
import { fallbackNav } from "../lib/routing";
import type { Alternate } from "../lib/alternates";

interface Props {
  seo?: PageSeo;
  article?: ArticleInput | null;
  /** Active locale — drives <html lang>, the per-locale menu, and SEO defaults. */
  locale?: Locale;
  /** This page in its other languages — header switcher + hreflang. */
  alternates?: Alternate[];
}

const { seo = {}, article = null, locale = DEFAULT_LOCALE, alternates = [] } = Astro.props;

// Site-wide theme + logo (Settings → Appearance / onboarding). Theme drives the
// public CSS via data-theme; logo (if set) replaces the text wordmark.
const theme = appearance.theme ?? "editorial";
const logo = appearance.logo || "";
const siteName = getSeoDefaults(locale).siteName || "Site";
const year = new Date().getFullYear();
const homeUrl = localeUrl(locale, "");

// Nav comes from the editable per-locale Settings → Menu — WordPress-style menu
// locations (header/footer), each with a per-device menu (tablet/mobile inherit
// desktop unless customized). groupByDevice dedupes inherited devices so we emit
// one <nav> per distinct list, revealed at its breakpoints by CSS (.resp/.at-*).
const menu = getMenu(locale);

// Header: if no header menu is defined at all, fall back to auto-listing this
// locale's published Pages so the nav is never blank.
let header = menu.header;
if (menuIsEmpty(header)) {
  const items = [{ label: "Home", url: homeUrl }, ...(await fallbackNav(locale))];
  header = { desktop: items, tablet: null, mobile: null };
}
const headerGroups = groupByDevice(header);
const footerGroups = menuIsEmpty(menu.footer) ? [] : groupByDevice(menu.footer);

// One group ⇒ every device shares one list ⇒ a plain always-visible nav. Two or
// three groups ⇒ each nav is `.resp` + one `.at-<device>` per device it serves.
function navClasses(base: string, groups: unknown[], devices: Device[]): string[] {
  if (groups.length <= 1) return [base];
  return [base, "resp", ...devices.map((d) => `at-${d}`)];
}
---

<!doctype html>
<html lang={locale} data-theme={theme}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <Seo seo={seo} article={article} locale={locale} alternates={alternates} />
  </head>
  <body>
    {
      theme === "liquid-glass" && (
        <svg width="0" height="0" style="position:absolute" aria-hidden="true" focusable="false">
          <filter id="glass-distortion" x="-20%" y="-20%" width="140%" height="140%">
            <feTurbulence type="fractalNoise" baseFrequency="0.008 0.012" numOctaves="2" seed="42" result="noise" />
            <feGaussianBlur in="noise" stdDeviation="2" result="blurred" />
            <feDisplacementMap in="SourceGraphic" in2="blurred" scale="36" xChannelSelector="R" yChannelSelector="G" />
          </filter>
        </svg>
      )
    }
    <header class="site-header">
      <div class="bar">
        <a class="brand" href={homeUrl}>
          {logo ? <img class="brand-logo" src={logo} alt={siteName} /> : siteName}
        </a>
        {
          headerGroups.map((g) => (
            <nav class:list={navClasses("site-nav", headerGroups, g.devices)}>
              {g.items.map((item) => <a href={item.url}>{item.label}</a>)}
            </nav>
          ))
        }
        {
          alternates.length > 1 && (
            <nav class="lang-switch" aria-label="Language">
              {alternates.map((alt) =>
                alt.locale === locale ? (
                  <span class="lang-current" aria-current="true">{LOCALE_LABEL[alt.locale]}</span>
                ) : (
                  <a href={alt.url} hreflang={alt.locale}>{LOCALE_LABEL[alt.locale]}</a>
                ),
              )}
            </nav>
          )
        }
      </div>
    </header>

    <slot />

    <footer class="site-footer">
      <div class="bar">
        {
          footerGroups.map((g) => (
            <nav class:list={navClasses("footer-nav", footerGroups, g.devices)} aria-label="Footer">
              {g.items.map((item) => <a href={item.url}>{item.label}</a>)}
            </nav>
          ))
        }
        <p class="footer-copy">© {year} {siteName}</p>
      </div>
    </footer>

    {/* Agent surface: window.lanza read API (see public/lanza.js). Static, deferred, cached site-wide. */}
    <script src="/lanza.js" defer is:inline></script>
  </body>
</html>
