---
import { getEntry, getCollection } from "astro:content";
import { sanitizeBody } from "../lib/sanitize";
import { priceLine, statusBadge, type Locale } from "../lib/listings";
import { resolveTemplate, templateClass, isLanding } from "../lib/templates";
import ListingCard from "./ListingCard.astro";

interface Props {
  listing: { id: string; data: Record<string, any>; body?: string };
  locale?: Locale;
  // Resolved template name (optional — self-resolved from the entry when absent).
  // Drives the <main> class + the landing chrome-drop, mirroring PageArticle.
  template?: string;
}
const { listing, locale = "es" } = Astro.props;
const d = listing.data;
const body = sanitizeBody(listing.body ?? "");

// Template variant (frontend/lib/templates.ts). "landing" drops the head/back
// chrome so the body is the page; default/full-width keep the wide listing shell.
const template = Astro.props.template ?? resolveTemplate(d);
const landing = isLanding(template);
const mainClass = [templateClass(template), !landing && "layout-wide", "listing"]
  .filter(Boolean)
  .join(" ");
const badge = statusBadge(d.listingStatus, locale);
const isEn = locale === "en";
const propsBase = isEn ? "/en/properties" : "/propiedades";

const agent = d.agent ? await getEntry("agents", d.agent) : undefined;
const region = d.region ? await getEntry("regions", d.region) : undefined;

// Similar: same region first, then other available listings. Exclude self.
const pool = (
  await getCollection("listings", ({ data }) =>
    import.meta.env.PROD ? data.draft !== true : true,
  )
).filter(
  (l) => l.id !== listing.id && l.data.listingStatus !== "sold" && l.data.listingStatus !== "rented",
);
const sameRegion = pool.filter((l) => d.region && l.data.region === d.region);
const similar = [...sameRegion, ...pool.filter((l) => !sameRegion.includes(l))].slice(0, 3);

const L = isEn
  ? { beds: "Bedrooms", baths: "Bathrooms", area: "Built area", lot: "Lot size", features: "Features", contact: "Contact agent", viewMap: "View on map", back: "← Back to properties", similar: "Similar properties" }
  : { beds: "Dormitorios", baths: "Baños", area: "Área construida", lot: "Lote", features: "Características", contact: "Contactar al asesor", viewMap: "Ver en el mapa", back: "← Volver a propiedades", similar: "Propiedades similares" };

const mapUrl =
  d.latitude != null && d.longitude != null
    ? `https://www.google.com/maps?q=${d.latitude},${d.longitude}`
    : null;
const gallery: Array<{ image: string; alt?: string }> = d.gallery ?? [];
---

<main class={mainClass}>
  {!landing && <a class="listing__back" href={propsBase}>{L.back}</a>}

  {!landing && (
    <header class="listing__head">
      <span class="lp-kicker">{region?.data.title ?? (isEn ? "Panama" : "Panamá")}</span>
      <h1>{d.title}</h1>
      <div class="listing__pricerow">
        <span class="lp-price">{priceLine(d, locale)}</span>
        {d.listingStatus !== "active" && <span class={`lp-badge ${badge.cls}`}>{badge.label}</span>}
      </div>
    </header>
  )}

  {d.featuredImage && (
    <img class="listing__hero" src={d.featuredImage} alt={d.title} width="1200" height="700" />
  )}

  <div class="listing__facts">
    {d.bedrooms != null && <div><strong>{d.bedrooms}</strong><span>{L.beds}</span></div>}
    {d.bathrooms != null && <div><strong>{d.bathrooms}</strong><span>{L.baths}</span></div>}
    {d.areaM2 != null && <div><strong>{d.areaM2} m²</strong><span>{L.area}</span></div>}
    {d.lotM2 != null && <div><strong>{d.lotM2} m²</strong><span>{L.lot}</span></div>}
  </div>

  {body && <article class="post-body" set:html={body} />}

  {d.features?.length > 0 && (
    <ul class="listing__features">
      {d.features.map((f: string) => <li>{f.replace(/_/g, " ")}</li>)}
    </ul>
  )}

  {mapUrl && (
    <a class="lp-btn lp-btn--ghost listing__map" href={mapUrl} target="_blank" rel="noopener">
      {L.viewMap} →
    </a>
  )}

  {agent && (
    <aside class="agent-card">
      {agent.data.photo && <img class="agent-card__photo" src={agent.data.photo} alt={agent.data.title} width="96" height="96" />}
      <div class="agent-card__body">
        <h2 class="agent-card__name">{agent.data.title}</h2>
        {agent.data.role && <p class="agent-card__role">{agent.data.role}</p>}
        <div class="agent-card__links">
          {agent.data.whatsapp && <a class="lp-btn lp-btn--accent" href={`https://wa.me/${agent.data.whatsapp}`} target="_blank" rel="noopener">WhatsApp</a>}
          {agent.data.email && <a class="lp-btn lp-btn--ghost" href={`mailto:${agent.data.email}`}>{L.contact}</a>}
        </div>
      </div>
    </aside>
  )}

  {similar.length > 0 && (
    <section class="listing__similar">
      <span class="lp-kicker">{L.similar}</span>
      <div class="listings-grid">
        {similar.map((l) => <ListingCard listing={l} locale={locale} />)}
      </div>
    </section>
  )}
</main>

<style>
  .listing { padding-top: 2rem; }
  .listing__back { display: inline-block; margin-bottom: 1.4rem; font-size: 0.75rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--muted); text-decoration: none; }
  .listing__back:hover { color: var(--ink); }
  .listing__head .lp-kicker { display: block; margin-bottom: 0.5rem; }
  .listing__head h1 { margin: 0 0 0.7rem; }
  .listing__pricerow { display: flex; align-items: center; gap: 1rem; margin-bottom: 1.6rem; }
  .listing__hero { width: 100%; aspect-ratio: 16/9; object-fit: cover; display: block; margin-bottom: 1.8rem; }
  .listing__facts { display: flex; flex-wrap: wrap; gap: 2.2rem; padding: 1.2rem 0; border-top: 1px solid var(--border-subtle); border-bottom: 1px solid var(--border-subtle); margin-bottom: 2rem; }
  .listing__facts div { display: flex; flex-direction: column; gap: 0.2rem; }
  .listing__facts strong { font-family: var(--font-heading); font-size: 1.5rem; font-weight: 500; }
  .listing__facts span { font-size: 0.72rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--muted); }
  .listing__features { list-style: none; padding: 0; margin: 1.8rem 0; display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .listing__features li { border: 1px solid var(--border); padding: 0.35rem 0.8rem; font-size: 0.78rem; letter-spacing: 0.06em; text-transform: capitalize; color: var(--text-secondary); }
  .listing__map { margin: 0.5rem 0 2.5rem; }
  .agent-card { display: flex; gap: 1.2rem; align-items: center; padding: 1.6rem; background: var(--surface); border: 1px solid var(--border-subtle); margin: 2.5rem 0; }
  .agent-card__photo { width: 96px; height: 96px; object-fit: cover; border-radius: 50%; flex: none; }
  .agent-card__name { margin: 0; font-size: 1.3rem; }
  .agent-card__role { margin: 0.2rem 0 0.9rem; color: var(--muted); font-size: 0.9rem; }
  .agent-card__links { display: flex; flex-wrap: wrap; gap: 0.7rem; }
  .listing__similar { margin-top: 3.5rem; border-top: 1px solid var(--border-subtle); padding-top: 2.2rem; }
  .listing__similar .lp-kicker { display: block; margin-bottom: 1.4rem; }
  .listings-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: 1.2rem; }
  @media (max-width: 560px) { .listings-grid { grid-template-columns: 1fr; } }
</style>
