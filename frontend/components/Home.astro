---
import { getCollection } from "astro:content";
import ListingCard from "./ListingCard.astro";
import { UI, type Locale } from "../lib/listings";
import { splitId } from "../lib/i18n";

interface Props {
  locale?: Locale;
}
const { locale = "es" } = Astro.props;
const isEn = locale === "en";
const t = UI[locale];
const propsBase = isEn ? "/en/properties" : "/propiedades";

const allListings = await getCollection("listings", ({ data }) =>
  import.meta.env.PROD ? data.draft !== true : true,
);
const activeListings = allListings
  .filter((l) => l.data.listingStatus !== "sold" && l.data.listingStatus !== "rented")
  .sort((a, b) => (b.data.pubDate?.valueOf() ?? 0) - (a.data.pubDate?.valueOf() ?? 0));
const gridListings = activeListings.slice(0, 4);

const posts = (
  await getCollection("posts", ({ data }) =>
    import.meta.env.PROD ? data.draft !== true : true,
  )
).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const latestPost = posts[0] ?? null;
const latestPostUrl = latestPost ? `/posts/${splitId(latestPost.id).slug}/` : "#";

const regions = (await getCollection("regions")).sort((a, b) =>
  a.data.title.localeCompare(b.data.title),
);

const hero = isEn
  ? {
      kicker: "Real estate · Panama",
      headline: "The pearl of the tropics, tailored to you",
      sub: "A curated selection of properties in Panama City, the Pacific coast and the highlands.",
      cta1: "Properties",
      cta2: "2-min quiz",
    }
  : {
      kicker: "Bienes raíces · Panamá",
      headline: "La perla del trópico, a su medida",
      sub: "Curaduría de propiedades en Ciudad de Panamá, la costa pacífica y las tierras altas.",
      cta1: "Propiedades",
      cta2: "Test de 2 min",
    };
const quizUrl = isEn ? "/en/find" : "/encuentra";
---

<section class="hero">
  <video
    class="hero__video"
    autoplay
    muted
    loop
    playsinline
    preload="auto"
    poster="/hero/panama-hero-poster.jpg"
    aria-hidden="true"
  >
    <source src="/hero/panama-hero.mp4" type="video/mp4" />
  </video>
  <div class="hero__content">
    <span class="lp-kicker">{hero.kicker}</span>
    <h1 class="hero__headline">{hero.headline}</h1>
    <p class="hero__sub">{hero.sub}</p>
    <div class="hero__ctas">
      <a class="lp-btn" href={propsBase}>{hero.cta1}</a>
      <a class="lp-btn lp-btn--ghost" href={quizUrl}>{hero.cta2}</a>
    </div>
  </div>
</section>

{gridListings.length > 0 && (
  <section class="listings-section">
    <div class="section-wrap">
      <header class="section-head">
        <span class="lp-kicker">{t.recentlyListed}</span>
        <a class="section-head__link" href={propsBase}>{t.viewAll} →</a>
      </header>
      <div class="listings-grid">
        {gridListings.map((l) => <ListingCard listing={l} locale={locale} />)}
      </div>
    </div>
  </section>
)}

{regions.length > 0 && (
  <section class="regions-section">
    <div class="section-wrap">
      <span class="lp-kicker">{t.regions}</span>
      <div class="regions-strip">
        {regions.map((r) => (
          <a class="region-link" href={`${propsBase}?region=${r.id}`}>{r.data.title}</a>
        ))}
      </div>
    </div>
  </section>
)}

{latestPost && (
  <section class="journal-section">
    <div class="section-wrap">
      <span class="lp-kicker">{t.journal}</span>
      <div class="journal-teaser">
        <h2 class="journal-teaser__title">{latestPost.data.title}</h2>
        {latestPost.data.description && (
          <p class="journal-teaser__excerpt">{latestPost.data.description}</p>
        )}
        <a class="journal-teaser__link" href={latestPostUrl}>{t.read} →</a>
      </div>
    </div>
  </section>
)}

<style>
  .hero { position: relative; display: flex; align-items: center; min-height: 86vh; overflow: hidden; background-color: var(--surface); }
  .hero__video { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; z-index: 0; }
  .hero::after {
    content: ""; position: absolute; inset: 0; z-index: 1;
    background:
      linear-gradient(90deg, rgba(16,32,42,.88) 0%, rgba(16,32,42,.6) 38%, rgba(16,32,42,.2) 68%, rgba(16,32,42,.05) 100%),
      linear-gradient(0deg, rgba(16,32,42,.55) 0%, rgba(16,32,42,0) 34%);
  }
  .hero__content { position: relative; z-index: 2; color: #f4efe6; display: flex; flex-direction: column; gap: 1.4rem; width: 100%; max-width: 600px; padding: 4rem 3rem; margin-left: clamp(1.25rem, 6vw, 6rem); }
  .hero__headline { font-size: clamp(2.6rem, 5vw, 4rem); line-height: 1.06; margin: 0; text-shadow: 0 1px 30px rgba(0,0,0,.35); }
  .hero__sub { font-size: 1.05rem; line-height: 1.65; color: rgba(244,239,230,.85); max-width: 42ch; }
  .hero__content .lp-kicker { color: #e8c8a0; }
  .hero__content .lp-btn--ghost { color: #f4efe6; border-color: rgba(244,239,230,.6); }
  .hero__ctas { display: flex; gap: 1rem; flex-wrap: wrap; margin-top: 0.4rem; }
  @media (prefers-reduced-motion: reduce) {
    .hero__video { display: none; }
    .hero { background-image: url("/hero/panama-hero-poster.jpg"); background-size: cover; background-position: center; }
  }

  .section-wrap { max-width: var(--wide-width, 1200px); margin: 0 auto; padding: 3rem 1.25rem 5rem; }
  .section-head { display: flex; align-items: baseline; justify-content: space-between; margin-bottom: 1.8rem; padding-bottom: 0.75rem; border-bottom: 1px solid var(--border-subtle); }
  .section-head__link { font-size: 0.8rem; letter-spacing: 0.08em; text-transform: uppercase; color: var(--muted); text-decoration: none; transition: color 120ms ease; }
  .section-head__link:hover { color: var(--ink); }

  .listings-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 1.2rem; }

  .regions-section { border-top: 1px solid var(--border-subtle); }
  .regions-section .section-wrap { padding-bottom: 3.5rem; }
  .regions-section .lp-kicker { display: block; margin-bottom: 1.4rem; }
  .regions-strip { display: flex; flex-wrap: wrap; gap: 0.6rem; }
  .region-link { display: inline-block; padding: 0.5rem 1rem; border: 1px solid var(--border); font-size: 0.82rem; letter-spacing: 0.06em; color: var(--text-secondary); text-decoration: none; transition: border-color 120ms ease, color 120ms ease; }
  .region-link:hover { border-color: var(--gold); color: var(--ink); }

  .journal-section { border-top: 1px solid var(--border-subtle); }
  .journal-section .lp-kicker { display: block; margin-bottom: 1.2rem; }
  .journal-teaser { display: grid; gap: 0.9rem; max-width: 56ch; }
  .journal-teaser__title { font-size: 1.8rem; margin: 0; }
  .journal-teaser__excerpt { color: var(--text-secondary); line-height: 1.65; margin: 0; }
  .journal-teaser__link { font-size: 0.78rem; letter-spacing: 0.14em; text-transform: uppercase; color: var(--gold); text-decoration: none; transition: color 120ms ease; }
  .journal-teaser__link:hover { color: var(--ink); }

  @media (max-width: 860px) {
    .hero { min-height: 68vh; }
    .hero__content { padding: 2.5rem 1.5rem; margin-left: 0; max-width: none; }
  }
  @media (max-width: 560px) {
    .hero__headline { font-size: 2.1rem; }
    .hero__ctas { flex-direction: column; align-items: flex-start; }
    .listings-grid { grid-template-columns: 1fr; }
  }
</style>
