---
import { getCollection } from "astro:content";
import ListingCard from "./ListingCard.astro";
import { UI, type Locale } from "../lib/listings";

interface Props {
  locale?: Locale;
}
const { locale = "es" } = Astro.props;
const t = UI[locale];

const listings = (
  await getCollection("listings", ({ data }) =>
    import.meta.env.PROD ? data.draft !== true : true,
  )
)
  .filter((l) => l.data.listingStatus !== "sold" && l.data.listingStatus !== "rented")
  .sort((a, b) => (b.data.pubDate?.valueOf() ?? 0) - (a.data.pubDate?.valueOf() ?? 0));

// Only regions that actually have listings get a filter chip.
const used = new Set(listings.map((l) => l.data.region).filter(Boolean));
const regions = (await getCollection("regions"))
  .filter((r) => used.has(r.id))
  .sort((a, b) => a.data.title.localeCompare(b.data.title));
---

<main class="layout-wide">
  <header class="props-head">
    <span class="lp-kicker">{t.properties}</span>
    <h1>{t.properties}</h1>
  </header>

  <div class="props-filters" id="region-filters">
    <button class="region-chip is-on" data-region="">{t.allRegions}</button>
    {regions.map((r) => (
      <button class="region-chip" data-region={r.id}>{r.data.title}</button>
    ))}
  </div>

  <div class="listings-grid" id="listings-grid">
    {listings.map((l) => <ListingCard listing={l} locale={locale} />)}
  </div>
  <p class="props-empty" id="props-empty" hidden>—</p>
</main>

<script is:inline>
  (function () {
    const grid = document.getElementById("listings-grid");
    const chips = Array.from(document.querySelectorAll("#region-filters .region-chip"));
    const empty = document.getElementById("props-empty");
    if (!grid) return;
    const cards = Array.from(grid.children);

    function apply(region) {
      let shown = 0;
      for (const card of cards) {
        const match = !region || card.getAttribute("data-region") === region;
        card.style.display = match ? "" : "none";
        if (match) shown++;
      }
      if (empty) empty.hidden = shown !== 0;
      for (const c of chips) c.classList.toggle("is-on", (c.getAttribute("data-region") || "") === region);
    }

    for (const c of chips) {
      c.addEventListener("click", function () {
        const region = c.getAttribute("data-region") || "";
        apply(region);
        const url = new URL(location.href);
        if (region) url.searchParams.set("region", region);
        else url.searchParams.delete("region");
        history.replaceState(null, "", url);
      });
    }

    const initial = new URLSearchParams(location.search).get("region") || "";
    apply(cards.some((c) => c.getAttribute("data-region") === initial) ? initial : "");
  })();
</script>

<style>
  .props-head { margin-bottom: 1.6rem; }
  .props-head .lp-kicker { display: block; margin-bottom: 0.5rem; }
  .props-head h1 { margin: 0; }
  .props-filters { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 2rem; padding-bottom: 1.4rem; border-bottom: 1px solid var(--border-subtle); }
  .region-chip { background: transparent; border: 1px solid var(--border); color: var(--text-secondary); padding: 0.45rem 0.95rem; font-size: 0.74rem; letter-spacing: 0.1em; text-transform: uppercase; cursor: pointer; font-family: var(--font-ui); transition: border-color 120ms, color 120ms, background 120ms; }
  .region-chip:hover { border-color: var(--gold); color: var(--ink); }
  .region-chip.is-on { background: var(--ink); color: var(--bg); border-color: var(--ink); }
  .listings-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 1.2rem; }
  .props-empty { color: var(--muted); padding: 2rem 0; }
  @media (max-width: 560px) { .listings-grid { grid-template-columns: 1fr; } }
</style>
