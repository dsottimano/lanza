---
import { getCollection, getEntry } from "astro:content";
import Base from "../../layouts/Base.astro";
import { sanitizeBody } from "../../lib/sanitize";
import type { ArticleInput } from "../../lib/jsonld";

export async function getStaticPaths() {
  const posts = await getCollection("posts", ({ data }) =>
    import.meta.env.PROD ? data.draft !== true : true,
  );
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
// Body is HTML authored in Lanza; render it directly (sanitized), not through
// the markdown pipeline. HTML is the source of truth (see lib/sanitize.ts).
const body = sanitizeBody(post.body ?? "");

const siteUrl = (Astro.site ?? new URL("/", Astro.url)).href.replace(/\/$/, "");
const url = new URL(Astro.url.pathname, siteUrl + "/").href;

// Featured image doubles as the social/og image and JSON-LD article image.
const ogImage = post.data.seo?.ogImage || post.data.featuredImage;

// Resolve the author relation to its display name (falls back to seo.author).
const authorEntry = post.data.author
  ? await getEntry("authors", post.data.author)
  : undefined;
const authorName = authorEntry?.data.title || post.data.seo?.author;

const article: ArticleInput = {
  title: post.data.title,
  description: post.data.description,
  image: ogImage,
  datePublished: post.data.pubDate.toISOString(),
  dateModified: (post.data.updatedDate ?? post.data.pubDate).toISOString(),
  author: authorName,
  url,
};
---

<Base
  seo={{
    title: post.data.title,
    description: post.data.description,
    ogType: "article",
    ...(post.data.seo ?? {}),
    ogImage,
  }}
  article={article}
>
  <main class={post.data.layout && post.data.layout !== "default" ? `layout-${post.data.layout}` : undefined}>
    <h1>{post.data.title}</h1>
    {
      authorName && (
        <p class="byline">
          By{" "}
          {authorEntry ? (
            <a href={`/author/${post.data.author}/`}>{authorName}</a>
          ) : (
            authorName
          )}
        </p>
      )
    }
    {
      post.data.featuredImage && (
        <img src={post.data.featuredImage} alt={post.data.title} />
      )
    }
    {
      (post.data.categories.length > 0 || post.data.tags.length > 0) && (
        <p class="taxonomy">
          {post.data.categories.map((c) => (
            <a href={`/category/${c}/`}>{c}</a>
          ))}
          {post.data.tags.map((t) => (
            <a href={`/tag/${t}/`}>#{t}</a>
          ))}
        </p>
      )
    }
    <article class="post-body" set:html={body} />
  </main>
</Base>
