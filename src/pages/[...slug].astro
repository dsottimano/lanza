---
import { getCollection } from "astro:content";
import Base from "../layouts/Base.astro";
import Blocks from "../components/Blocks.astro";
import { sanitizeBody } from "../lib/sanitize";

// Standalone Pages (About, Contact, …) render at /<slug>. Static paths only —
// this is not a runtime catch-all; getStaticPaths emits exactly the page slugs.
export async function getStaticPaths() {
  const pages = await getCollection("pages", ({ data }) =>
    import.meta.env.PROD ? data.draft !== true : true,
  );
  return pages.map((page) => ({ params: { slug: page.id }, props: { page } }));
}

const { page } = Astro.props;
const body = sanitizeBody(page.body ?? "");
---

<Base
  seo={{
    title: page.data.title,
    description: page.data.description,
    ogType: "website",
    ...(page.data.seo ?? {}),
    ogImage: page.data.seo?.ogImage || page.data.featuredImage,
  }}
>
  <main>
    <h1>{page.data.title}</h1>
    {
      page.data.featuredImage && (
        <img src={page.data.featuredImage} alt={page.data.title} />
      )
    }
    {page.data.blocks.length > 0 && <Blocks blocks={page.data.blocks} />}
    <article class="post-body" set:html={body} />
  </main>
</Base>
