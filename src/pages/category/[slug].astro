---
import { getCollection } from "astro:content";
import Base from "../../layouts/Base.astro";

export async function getStaticPaths() {
  const categories = await getCollection("categories");
  return categories.map((category) => ({
    params: { slug: category.id },
    props: { category },
  }));
}

const { category } = Astro.props;
const posts = (
  await getCollection(
    "posts",
    ({ data }) =>
      (import.meta.env.PROD ? data.draft !== true : true) &&
      data.categories.includes(category.id),
  )
).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

// Hierarchy: resolve the parent (breadcrumb) and any child categories.
const allCategories = await getCollection("categories");
const parent = category.data.parent
  ? allCategories.find((c) => c.id === category.data.parent)
  : undefined;
const children = allCategories
  .filter((c) => c.data.parent === category.id)
  .sort((a, b) => a.data.title.localeCompare(b.data.title));
---

<Base
  seo={{
    title: `Category: ${category.data.title}`,
    description: category.data.description,
  }}
>
  <main>
    {
      parent && (
        <p class="breadcrumb">
          <a href={`/category/${parent.id}/`}>{parent.data.title}</a> /
        </p>
      )
    }
    <h1>Category: {category.data.title}</h1>
    {category.data.description && <p>{category.data.description}</p>}
    {
      children.length > 0 && (
        <nav class="subcategories">
          <strong>Subcategories:</strong>
          <ul>
            {children.map((c) => (
              <li>
                <a href={`/category/${c.id}/`}>{c.data.title}</a>
              </li>
            ))}
          </ul>
        </nav>
      )
    }
    {
      posts.length > 0 ? (
        <ul>
          {posts.map((p) => (
            <li>
              <a href={`/posts/${p.id}/`}>{p.data.title}</a>
            </li>
          ))}
        </ul>
      ) : (
        <p>No posts in this category yet.</p>
      )
    }
  </main>
</Base>
