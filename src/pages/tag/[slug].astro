---
import { getCollection } from "astro:content";
import Base from "../../layouts/Base.astro";

export async function getStaticPaths() {
  const tags = await getCollection("tags");
  return tags.map((tag) => ({ params: { slug: tag.id }, props: { tag } }));
}

const { tag } = Astro.props;
const posts = (
  await getCollection(
    "posts",
    ({ data }) =>
      (import.meta.env.PROD ? data.draft !== true : true) &&
      data.tags.includes(tag.id),
  )
).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<Base
  seo={{ title: `Tag: ${tag.data.title}`, description: tag.data.description }}
>
  <main>
    <h1>Tag: {tag.data.title}</h1>
    {tag.data.description && <p>{tag.data.description}</p>}
    {
      posts.length > 0 ? (
        <ul>
          {posts.map((p) => (
            <li>
              <a href={`/posts/${p.id}/`}>{p.data.title}</a>
            </li>
          ))}
        </ul>
      ) : (
        <p>No posts with this tag yet.</p>
      )
    }
  </main>
</Base>
