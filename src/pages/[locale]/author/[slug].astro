---
import { getCollection } from "astro:content";
import Base from "../../../layouts/Base.astro";
import Archive from "../../../components/Archive.astro";
import { LOCALES, splitId, DEFAULT_LOCALE } from "../../../lib/i18n";
import { allLocaleAlternates } from "../../../lib/alternates";

// Localized author archives (/es/author/x/). Authors are shared (not localized),
// so we emit each author under every non-default locale, listing that locale's
// posts by them.
export async function getStaticPaths() {
  const authors = await getCollection("authors");
  const locales = LOCALES.filter((l) => l !== DEFAULT_LOCALE);
  return authors.flatMap((author) =>
    locales.map((locale) => ({
      params: { locale, slug: author.id },
      props: { author, locale },
    })),
  );
}

const { author, locale } = Astro.props;
const posts = (
  await getCollection(
    "posts",
    ({ data }) =>
      (import.meta.env.PROD ? data.draft !== true : true) &&
      data.author === author.id,
  )
)
  .filter((p) => splitId(p.id).locale === locale)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const alternates = allLocaleAlternates(`author/${author.id}/`);
---

<Base
  locale={locale}
  alternates={alternates}
  seo={{ title: author.data.title, description: author.data.bio }}
>
  {author.data.avatar && <img src={author.data.avatar} alt={author.data.title} />}
  <Archive
    heading={author.data.title}
    locale={locale}
    posts={posts}
    description={author.data.bio}
    emptyText="No posts by this author yet."
  />
</Base>
