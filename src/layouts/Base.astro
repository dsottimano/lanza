---
import Seo from "../components/Seo.astro";
import type { PageSeo } from "../lib/seo";
import type { ArticleInput } from "../lib/jsonld";

interface Props {
  seo?: PageSeo;
  article?: ArticleInput | null;
}

const { seo = {}, article = null } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <Seo seo={seo} article={article} />
  </head>
  <body>
    <slot />
  </body>
</html>
