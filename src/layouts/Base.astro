---
import "../styles/site.css";
import Seo from "../components/Seo.astro";
import { getCollection } from "astro:content";
import menu from "../data/menu.json";
import seoDefaults from "../data/seo.json";
import appearance from "../data/appearance.json";
import type { PageSeo } from "../lib/seo";
import type { ArticleInput } from "../lib/jsonld";

interface Props {
  seo?: PageSeo;
  article?: ArticleInput | null;
}

const { seo = {}, article = null } = Astro.props;

// Site-wide theme (Settings → Appearance). Drives the public CSS via data-theme.
const theme = appearance.theme ?? "editorial";
const siteName = seoDefaults.siteName || "Site";
const year = new Date().getFullYear();

// Nav comes from the editable Settings → Menu (WordPress-style). If it's empty,
// fall back to auto-listing published Pages so the nav is never blank.
let navItems = menu.items ?? [];
if (navItems.length === 0) {
  const pages = (
    await getCollection("pages", ({ data }) =>
      import.meta.env.PROD ? data.draft !== true : true,
    )
  ).sort((a, b) => a.data.title.localeCompare(b.data.title));
  navItems = [
    { label: "Home", url: "/" },
    ...pages.map((p) => ({ label: p.data.title, url: `/${p.id}/` })),
  ];
}
---

<!doctype html>
<html lang="en" data-theme={theme}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <Seo seo={seo} article={article} />
  </head>
  <body>
    <header class="site-header">
      <div class="bar">
        <a class="brand" href="/">{siteName}</a>
        <nav class="site-nav">
          {navItems.map((item) => <a href={item.url}>{item.label}</a>)}
        </nav>
      </div>
    </header>

    <slot />

    <footer class="site-footer">
      <div class="bar">© {year} {siteName}</div>
    </footer>

    {/* Agent surface: window.lanza read API (see public/lanza.js). Static, deferred, cached site-wide. */}
    <script src="/lanza.js" defer is:inline></script>
  </body>
</html>
