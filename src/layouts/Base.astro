---
import Seo from "../components/Seo.astro";
import { getCollection } from "astro:content";
import type { PageSeo } from "../lib/seo";
import type { ArticleInput } from "../lib/jsonld";

interface Props {
  seo?: PageSeo;
  article?: ArticleInput | null;
}

const { seo = {}, article = null } = Astro.props;

// Pages appear in the site nav (WordPress-style menu). Build-time only.
const pages = (
  await getCollection("pages", ({ data }) =>
    import.meta.env.PROD ? data.draft !== true : true,
  )
).sort((a, b) => a.data.title.localeCompare(b.data.title));
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <Seo seo={seo} article={article} />
  </head>
  <body>
    <header>
      <nav>
        <a href="/">Home</a>
        {pages.map((p) => <a href={`/${p.id}/`}>{p.data.title}</a>)}
      </nav>
    </header>
    <slot />
  </body>
</html>
