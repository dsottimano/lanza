---
import Seo from "../components/Seo.astro";
import { getCollection } from "astro:content";
import menu from "../data/menu.json";
import type { PageSeo } from "../lib/seo";
import type { ArticleInput } from "../lib/jsonld";

interface Props {
  seo?: PageSeo;
  article?: ArticleInput | null;
}

const { seo = {}, article = null } = Astro.props;

// Nav comes from the editable Settings → Menu (WordPress-style). If it's empty,
// fall back to auto-listing published Pages so the nav is never blank.
let navItems = menu.items ?? [];
if (navItems.length === 0) {
  const pages = (
    await getCollection("pages", ({ data }) =>
      import.meta.env.PROD ? data.draft !== true : true,
    )
  ).sort((a, b) => a.data.title.localeCompare(b.data.title));
  navItems = [
    { label: "Home", url: "/" },
    ...pages.map((p) => ({ label: p.data.title, url: `/${p.id}/` })),
  ];
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <Seo seo={seo} article={article} />
  </head>
  <body>
    <header>
      <nav>
        {navItems.map((item) => <a href={item.url}>{item.label}</a>)}
      </nav>
    </header>
    <slot />

    <!-- Card styles for Lanza-authored content (callout / figure / embed).
         The editor stores these as static HTML; this is the matching public
         CSS. Scoped to the cards only — not a site-wide theme. -->
    <style is:global>
      .post-body .callout {
        display: flex;
        gap: 0.7rem;
        padding: 1rem 1.2rem;
        margin: 1.5em 0;
        background: #f4f6f8;
        border-radius: 10px;
      }
      .post-body .callout::before {
        content: attr(data-emoji);
        flex: 0 0 auto;
        font-size: 1.2rem;
        line-height: 1.6;
      }
      .post-body .figure {
        margin: 1.6em 0;
        text-align: center;
      }
      .post-body .figure img {
        max-width: 100%;
        height: auto;
        border-radius: 8px;
      }
      .post-body .figure figcaption {
        margin-top: 0.6em;
        font-size: 0.9rem;
        color: #6b7280;
      }
      .post-body .embed {
        margin: 1.6em 0;
      }
      .post-body .embed iframe {
        display: block;
        width: 100%;
        aspect-ratio: 16 / 9;
        border: 0;
        border-radius: 8px;
      }
    </style>
  </body>
</html>
