# Copy this file to `.env` and fill in the values. `.env` is gitignored.

# Required. EmDash uses this to encrypt secrets (e.g. plugin credentials) at rest.
# Generate one with:  openssl rand -base64 32
EMDASH_ENCRYPTION_KEY=

# Optional. Public origin of the deployed site, used for canonical URLs,
# sitemap, and preview links. Falls back to the request origin if unset.
# EMDASH_SITE_URL=https://example.com

# Auth providers configured in astro.config.mjs (e.g. Google) may need their
# own credentials — add them here as needed, e.g.:
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
