---
/*
 * Pattern-driven catch-all route.
 *
 * This is what makes the admin "URL Pattern" field authoritative. Instead of a
 * hardcoded file route, it asks EmDash to resolve the requested path against
 * every collection's configured `urlPattern` (e.g. pages = "/{slug}",
 * docs = "/help/{slug}") and renders whatever matches.
 *
 * Priority: Astro tries specific routes first (/, /posts/[slug], /category/...
 * /tag/..., /search), so this rest route only fires for paths none of those
 * match — i.e. content whose pattern points outside those reserved trees.
 */
import { resolveEmDashPath, getEmDashEntry } from "emdash";
import { PortableText } from "emdash/ui";
import Base from "../layouts/Base.astro";
import { resolveLayout } from "../utils/layout-width";

const path = `/${Astro.params.path ?? ""}`;

// Ask EmDash which collection + entry (if any) this path maps to, using the
// admin-configured URL patterns.
const resolved = await resolveEmDashPath(path);

if (!resolved) {
	return Astro.redirect("/404");
}

const { collection, params } = resolved;
const slug = params.slug;

// Re-fetch through getEmDashEntry to obtain the cache hint and the visual-editor
// edit proxy (resolveEmDashPath returns the entry but not these).
const { entry, cacheHint } = await getEmDashEntry(collection, slug);

if (!entry) {
	return Astro.redirect("/404");
}

if (Astro.cache?.enabled) Astro.cache.set(cacheHint);

const title = typeof entry.data.title === "string" ? entry.data.title : slug;
const entryId = String(entry.data.id);

// Per-entry width / margin (admin-configurable; see utils/layout-width.ts).
const layout = resolveLayout(entry.data as Record<string, unknown>);
---

<Base title={title} content={{ collection, id: entryId, slug }}>
	<article class="page-article" {...layout}>
		<header class="page-header">
			<h1 class="page-title" {...entry.edit.title}>{title}</h1>
		</header>

		{
			entry.data.content && (
				<div class="page-content">
					<PortableText value={entry.data.content} />
				</div>
			)
		}
	</article>
</Base>

<style>
	.page-article {
		max-width: var(--page-max-width, var(--content-width));
		margin: 0 auto;
		padding: var(--spacing-16) var(--page-pad-x, var(--spacing-6))
			var(--spacing-16);
	}

	/* Per-entry width presets (the `data-width` attr from resolveLayout). */
	.page-article[data-width="wide"] {
		--page-max-width: var(--wide-width);
	}
	.page-article[data-width="narrow"] {
		--page-max-width: 36rem;
	}
	.page-article[data-width="full"] {
		--page-max-width: none;
	}

	.page-header {
		margin-bottom: var(--spacing-8);
	}

	.page-title {
		font-family: var(--font-serif);
		font-size: clamp(var(--font-size-2xl), 4vw, var(--font-size-4xl));
		font-weight: 700;
		line-height: var(--leading-tight);
		letter-spacing: var(--tracking-tight);
	}

	.page-content :global(p) {
		margin-bottom: 1.5em;
	}

	.page-content :global(h2) {
		font-family: var(--font-serif);
		font-weight: 400;
		font-size: var(--font-size-2xl);
		margin-top: 2em;
		margin-bottom: 0.75em;
	}

	.page-content :global(h3) {
		font-family: var(--font-serif);
		font-weight: 700;
		font-size: var(--font-size-xl);
		margin-top: 1.75em;
		margin-bottom: 0.5em;
	}

	.page-content :global(blockquote) {
		margin: 1.5em 0;
		padding-left: var(--spacing-6);
		border-left: 3px solid var(--color-accent);
		color: var(--color-text-secondary);
		font-family: var(--font-serif);
		font-style: italic;
	}

	.page-content :global(pre) {
		margin: 1.5em 0;
		padding: var(--spacing-4);
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		border-radius: var(--radius);
		overflow-x: auto;
		font-family: var(--font-mono);
		font-size: var(--font-size-sm);
	}

	.page-content :global(code) {
		font-family: var(--font-mono);
		font-size: 0.9em;
		background: var(--color-surface);
		padding: 0.15em 0.3em;
		border-radius: var(--radius);
	}

	.page-content :global(pre code) {
		background: none;
		padding: 0;
	}

	.page-content :global(ul),
	.page-content :global(ol) {
		margin-bottom: 1.5em;
		padding-left: var(--spacing-5);
	}

	.page-content :global(li) {
		margin-bottom: 0.5em;
	}
</style>
