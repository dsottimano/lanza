---
import { buildSeo, type PageSeo } from "../lib/seo";

interface Props {
  seo?: PageSeo;
}

const { seo = {} } = Astro.props;
const s = buildSeo(seo);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{s.title}</title>
    <meta name="description" content={s.description} />
    <meta property="og:title" content={s.title} />
    <meta property="og:description" content={s.description} />
    <meta property="og:site_name" content={s.siteName} />
    {s.ogImage && <meta property="og:image" content={s.ogImage} />}
    <meta name="twitter:card" content="summary_large_image" />
    {s.twitter && <meta name="twitter:site" content={s.twitter} />}
  </head>
  <body>
    <slot />
  </body>
</html>
