{
  "name": "@lanza/site",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "lanza": "bin/lanza.mjs"
  },
  "exports": {
    "./astro": "./astro-config.mjs"
  },
  "files": [
    "astro-config.mjs",
    "bin",
    "frontend",
    "functions",
    "public/admin",
    "public/brand",
    "public/favicon",
    "public/social",
    "public/lanza.js",
    "scripts"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "build:admin": "npm --prefix admin ci && npm --prefix admin run build",
    "build": "npm run build:admin && node bin/lanza.mjs build",
    "prepack": "npm run build:admin",
    "preview": "astro preview",
    "check": "astro check"
  },
  "dependencies": {
    "astro": "7.0.3",
    "isomorphic-dompurify": "3.18.0"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.9",
    "typescript": "6.0.3"
  }
}
